@{
    ViewData["Title"] = "Skills";
}

<section class="py-5">

    <div class="container">

        <div class="text-center mb-5">
            <h1 class="display-4 fw-bold">
                Technical Skills
            </h1>

            <p class="lead text-muted">
                Here are the technologies and tools I have learned and continue to improve.
            </p>
        </div>

        <div class="row g-4">

            <div class="col-lg-3 col-md-6">
                <div class="card h-100 shadow-sm border-0 text-center">

                    <div class="card-body">

                        <i class="bi bi-file-earmark-code text-primary display-4"></i>

                        <h4 class="fw-bold mt-3">
                            Languages
                        </h4>

                        <p class="text-muted">
                            @ViewData["Languages"]
                        </p>

                    </div>

                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="card h-100 shadow-sm border-0 text-center">

                    <div class="card-body">

                        <i class="bi bi-globe text-success display-4"></i>

                        <h4 class="fw-bold mt-3">
                            Web Development
                        </h4>

                        <p class="text-muted">
                            @ViewData["Framework"]
                        </p>

                    </div>

                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="card h-100 shadow-sm border-0 text-center">

                    <div class="card-body">

                        <i class="bi bi-database text-warning display-4"></i>

                        <h4 class="fw-bold mt-3">
                            Database
                        </h4>

                        <p class="text-muted">
                            @ViewData["Database"]
                        </p>

                    </div>

                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="card h-100 shadow-sm border-0 text-center">

                    <div class="card-body">

                        <i class="bi bi-tools text-danger display-4"></i>

                        <h4 class="fw-bold mt-3">
                            Development Tools
                        </h4>

                        <p class="text-muted">
                            @ViewData["Developer Tools"]
                        </p>

                    </div>

                </div>
            </div>

        </div>

        <hr class="my-5" />

        <div class="text-center">

            <h3 class="fw-bold mb-4">
                My Learning Philosophy
            </h3>

            <p class="lead text-muted mx-auto" style="max-width:750px;">
                I continuously improve my technical skills by developing projects,
                studying modern technologies, and practicing problem-solving.
                I believe learning never stops, especially in the field of Information Technology.
            </p>

        </div>

    </div>

</section>