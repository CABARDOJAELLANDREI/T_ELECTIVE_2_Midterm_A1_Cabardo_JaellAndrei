@{
    ViewData["Title"] = "Projects";
}

<section class="py-5">

    <div class="container">

        <div class="text-center mb-5">

            <h1 class="display-4 fw-bold">
                My Projects
            </h1>

            <p class="lead text-muted">
                Here are some projects that represent my programming and software development skills.
            </p>

        </div>


        <div class="row g-4">


            <div class="col-lg-4 col-md-6">

                <div class="card h-100 shadow-sm border-0 overflow-hidden">

                    <img src="~/lib/images/project1.png"
                         class="card-img-top"
                         style="height:200px;object-fit:cover;"
                         alt="Project Dashboard" />


                    <div class="card-body d-flex flex-column">

                        <h4 class="fw-bold text-dark">
                            @ViewData["Project1"]
                        </h4>


                        <p class="text-muted flex-grow-1">
                            A management parking system designed to monitor driver's information,
                            parking slots, and display important data using a Microsoft Access Interface.
                        </p>


                        <div class="mb-3">

                            <span class="badge bg-dark">
                                Microsoft Access
                            </span>

                        </div>


                        <button class="btn btn-outline-primary">
                            View Details
                        </button>


                    </div>

                </div>

            </div>



            <div class="col-lg-4 col-md-6">

                <div class="card h-100 shadow-sm border-0 overflow-hidden">


                    <img src="~/lib/images/2.png"
                         class="card-img-top"
                         style="height:200px;object-fit:cover;"
                         alt="Chat Application" />


                    <div class="card-body d-flex flex-column">


                        <h4 class="fw-bold text-dark">
                            @ViewData["Project2"]
                        </h4>


                        <p class="text-muted flex-grow-1">
                            A loan application system that offers you to loan money.
                        </p>


                        <div class="mb-3">

                            <span class="badge bg-danger">
                                Visual Studio
                            </span>

                            <span class="badge bg-warning text-dark">
                                Visual Basic
                            </span>

                            <span class="badge bg-info text-dark">
                                VB.Net
                            </span>

                        </div>


                        <button class="btn btn-outline-primary">
                            View Details
                        </button>


                    </div>

                </div>

            </div>




            <div class="col-lg-4 col-md-6">

                <div class="card h-100 shadow-sm border-0 overflow-hidden">


                    <img src="~/lib/images/3.png"
                         class="card-img-top"
                         style="height:200px;object-fit:cover;"
                         alt="Task Management" />


                    <div class="card-body d-flex flex-column">


                        <h4 class="fw-bold text-dark">
                            @ViewData["Project3"]
                        </h4>


                        <p class="text-muted flex-grow-1">
                            Im currently make a Parking Management System as my Midterm Project.
                        </p>


                        <div class="mb-3">

                            <span class="badge bg-primary">
                                Python
                            </span>

                            <span class="badge bg-secondary">
                                CTkinter
                            </span>

                            <span class="badge bg-success">
                                Pycharm
                            </span>

                        </div>


                        <button class="btn btn-outline-primary">
                            View Details
                        </button>


                    </div>

                </div>

            </div>


        </div>

    </div>


</section>