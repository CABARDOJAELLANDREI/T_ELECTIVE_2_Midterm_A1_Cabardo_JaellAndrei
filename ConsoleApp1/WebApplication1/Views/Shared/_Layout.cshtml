<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8"/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
		<title>@ViewData["Title"] - Personal Portfolio</title>
		<!-- Bootstrap Icons for navigation design -->
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
		<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
		<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
		<link class="text-white" rel="stylesheet" href="~/WebApplication1.styles.css" asp-append-version="true" />
	</head>
	<body>

		<div class="container-fluid">
			<div class="row">
				<!-- Responsive Dark Sidebar Navigation (bg-dark added back here) -->
				<nav id="sidebarMenu" class="col-md-3 col-lg-2 d-md-block sidebar collapse bg-dark" style="background-color: #212529 !important; min-height: 100vh;">
					<div class="position-sticky pt-3 d-flex flex-column justify-content-between h-100">
						<div>
							<!-- Profile Photo, Name & Title in Sidebar -->
							<div class="text-center px-3 mb-4 text-white border-bottom border-light border-opacity-25 pb-3">
								<img src="~/lib/images/formalpic.jpg"
									 alt="Jaell Andrei Cabardo"
									 class="img-fluid rounded-circle shadow mb-3 mt-2 border border-4 border-white-50"
									 style="width: 110px; height: 110px; object-fit: cover;" />

								<h5 class="fw-bold mb-1 fs-5 text-white" style="color: #ffffff !important;">Jaell Andrei Cabardo</h5>

					
								<small class="d-block fs-7" style="color: #ffffff !important; font-weight: 500;">Aspiring Software Developer</small>
							</div>

							<ul class="nav flex-column px-2">
								<li class="nav-item mb-2">
									<a class="nav-link text-white active" href="#home" style="color: #ffffff !important;">
										<i class="bi bi-house-door me-2"></i> Home
									</a>
								</li>
								<li class="nav-item mb-2">
									<a class="nav-link text-white" href="#about" style="color: #ffffff !important;">
										<i class="bi bi-person me-2"></i> About Me
									</a>
								</li>
								<li class="nav-item mb-2">
									<a class="nav-link text-white" href="#skills" style="color: #ffffff !important;">
										<i class="bi bi-code-slash me-2"></i> Skills
									</a>
								</li>
								<li class="nav-item mb-2">
									<a class="nav-link text-white" href="#projects" style="color: #ffffff !important;">
										<i class="bi bi-laptop me-2"></i> Projects
									</a>
								</li>
								<li class="nav-item mb-2">
									<a class="nav-link text-white" href="#contact" style="color: #ffffff !important;">
										<i class="bi bi-envelope me-2"></i> Contact
									</a>
								</li>
							</ul>
						</div>

						<!-- Sidebar Footer (Forced to pure white) -->
						<div class="p-3 text-center border-top border-light border-opacity-10">
							<small style="color: #ffffff !important;">© 2026 - Portfolio</small>
						</div>
					</div>
				</nav>

				<!-- Mobile Header Bar (Only visible on Mobile/Tablets) -->
				<header class="navbar navbar-dark sticky-top bg-dark flex-md-nowrap p-0 shadow d-md-none">
					<a class="navbar-brand col-md-3 col-lg-2 me-0 px-3 fs-6" href="#home">My Portfolio</a>
					<button class="navbar-toggler position-absolute d-md-none collapsed m-2" type="button"
							data-bs-toggle="collapse" data-bs-target="#sidebarMenu"
							aria-controls="sidebarMenu" aria-expanded="false" aria-label="Toggle navigation">
						<span class="navbar-toggler-icon"></span>
					</button>
				</header>

				<!-- Main Content Area -->
				<main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 main-content">
					<div class="container py-4">
						<!-- RENDERBODY BELONGS HERE -->
						@RenderBody()
					</div>
				</main>
			</div>
		</div>

		<script src="~/lib/jquery/dist/jquery.min.js"></script>
		<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
		<script src="~/js/site.js" asp-append-version="true"></script>
		@await RenderSectionAsync("Scripts", required: false)
	</body>
</html>